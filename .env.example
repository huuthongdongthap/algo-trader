# AlgoTrade Bot — Environment Configuration
# Copy: cp .env.example .env → fill in your credentials
# NEVER commit .env to git!

# ═══════════ REQUIRED FOR TRADING ═══════════

# Polymarket CLOB API (from polymarket.com → Settings → API Keys)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=

# ═══════════ LLM CONFIGURATION (Dual-Model) ═══════════
# Primary gateway: DeepSeek R1 Distill 32B (deep reasoning, port 11435)
# Scanner gateway: Nemotron-3 Nano 30B (fast inference, 35-50 t/s, port 11436)

OPENCLAW_GATEWAY_URL=http://192.168.11.111:11435/v1
OPENCLAW_SCANNER_URL=http://192.168.11.111:11436/v1
OPENCLAW_MODEL_SIMPLE=mlx-community/NVIDIA-Nemotron-3-Nano-30B-A3B-4bit
OPENCLAW_MODEL_STANDARD=mlx-community/DeepSeek-R1-Distill-Qwen-32B-4bit
OPENCLAW_MODEL_COMPLEX=mlx-community/DeepSeek-R1-Distill-Qwen-32B-4bit
OPENCLAW_TIMEOUT_MS=300000

# Fallback configuration (optional, for high-availability)
LLM_PRIMARY_URL=http://192.168.11.111:11436/v1
LLM_PRIMARY_MODEL=mlx-community/NVIDIA-Nemotron-3-Nano-30B-A3B-4bit
LLM_FALLBACK_URL=http://192.168.11.111:11435/v1
LLM_FALLBACK_MODEL=mlx-community/DeepSeek-R1-Distill-Qwen-32B-4bit

# ═══════════ DATA ═══════════

DATABASE_PATH=data/algo-trade.db

# ═══════════ TRADING DEFAULTS ═══════════

# Paper trading is ON by default (safe). Set to false for live execution.
PAPER_TRADING=true

# Starting capital in USDC
CAPITAL_USDC=200

# ═══════════ OPTIONAL ═══════════

# Telegram Alerts
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
