# AlgoTrade Bot — Environment Configuration
# Copy: cp .env.example .env → fill in your credentials
# NEVER commit .env to git!

# ═══════════ REQUIRED FOR TRADING ═══════════

# License (from admin)
LICENSE_KEY=
LICENSE_SECRET=

# Polymarket CLOB API (from polymarket.com → Settings → API Keys)
POLYMARKET_API_KEY=
POLYMARKET_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# Wallet private key (from MetaMask export)
POLY_PRIVATE_KEY=0x

# Trading capital
CAPITAL_USDC=500

# ═══════════ LLM INFERENCE ═══════════

# macOS MLX (default for Apple Silicon):
LLM_PRIMARY_URL=http://127.0.0.1:11435/v1
LLM_PRIMARY_MODEL=mlx-community/DeepSeek-R1-Distill-Qwen-32B-4bit

# Ubuntu VPS Ollama (uncomment if using VPS):
# LLM_PRIMARY_URL=http://127.0.0.1:11434/v1
# LLM_PRIMARY_MODEL=deepseek-r1:32b

# ═══════════ OPTIONAL ═══════════

# General
NODE_ENV=production
LOG_LEVEL=info
DB_PATH=./data/algo-trade.db

# Risk Management
MAX_POSITION_SIZE=10000
MAX_DRAWDOWN=0.20
MAX_OPEN_POSITIONS=10
STOP_LOSS_PERCENT=0.10
MAX_LEVERAGE=2

# Polygon RPC
POLYGON_RPC_URL=https://polygon-rpc.com

# Telegram Alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# Admin (for stats server only)
ADMIN_PASSWORD=change-me-in-production

# Polar.sh Billing (RaaS subscriptions)
POLAR_API_TOKEN=
